  "uninstaller": {
    "script": [
      "$fontFiles = @(\"Athiti-ExtraLight.ttf\", \"Athiti-Light.ttf\", \"Athiti-Regular.ttf\", \"Athiti-Medium.ttf\", \"Athiti-SemiBold.ttf\", \"Athiti-Bold.ttf\") foreach ($file in $fontFiles) {     $fontName = [System.IO.Path]::GetFileNameWithoutExtension($file)     Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name \"$fontName (TrueType)\" -ErrorAction SilentlyContinue     Remove-Item \"$env:windir\\Fonts\\$file\" -Force -ErrorAction SilentlyContinue }"
    ]
