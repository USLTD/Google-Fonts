      "https://raw.githubusercontent.com/google/fonts/main/ofl/athiti/Athiti-Light.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/athiti/Athiti-Regular.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/athiti/Athiti-Medium.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/athiti/Athiti-SemiBold.ttf",
