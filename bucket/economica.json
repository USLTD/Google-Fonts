  ],
  "homepage": "https://fonts.google.com/specimen/Economica",
  "url": [
    "https://raw.githubusercontent.com/google/fonts/main/ofl/economica/Economica-Regular.ttf",
    "https://raw.githubusercontent.com/google/fonts/main/ofl/economica/Economica-Italic.ttf",
    "https://raw.githubusercontent.com/google/fonts/main/ofl/economica/Economica-Bold.ttf",
    "https://raw.githubusercontent.com/google/fonts/main/ofl/economica/Economica-BoldItalic.ttf"
  ],
  "checkver": {
    "url": "https://api.github.com/repos/google/fonts/commits?path=ofl/economica&per_page=1",
    "regex": "\"sha\":\\s*\"([a-f0-9]{7})"
  },
  "uninstaller": {
    "script": [
      "$fontFiles = @(\"Economica-Regular.ttf\", \"Economica-Italic.ttf\", \"Economica-Bold.ttf\", \"Economica-BoldItalic.ttf\") foreach ($file in $fontFiles) {     $fontName = [System.IO.Path]::GetFileNameWithoutExtension($file)     Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name \"$fontName (TrueType)\" -ErrorAction SilentlyContinue     Remove-Item \"$env:windir\\Fonts\\$file\" -Force -ErrorAction SilentlyContinue }"
    ]
  }
}
