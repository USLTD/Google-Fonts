  "uninstaller": {
    "script": [
      "$fontFiles = @(\"DMMono-Light.ttf\", \"DMMono-LightItalic.ttf\", \"DMMono-Regular.ttf\", \"DMMono-Italic.ttf\", \"DMMono-Medium.ttf\", \"DMMono-MediumItalic.ttf\") foreach ($file in $fontFiles) {     $fontName = [System.IO.Path]::GetFileNameWithoutExtension($file)     Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name \"$fontName (TrueType)\" -ErrorAction SilentlyContinue     Remove-Item \"$env:windir\\Fonts\\$file\" -Force -ErrorAction SilentlyContinue }"
    ]
  }
