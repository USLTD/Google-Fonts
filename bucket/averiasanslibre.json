  "autoupdate": {
    "url": [
      "https://raw.githubusercontent.com/google/fonts/main/ofl/averiasanslibre/AveriaSansLibre-Light.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/averiasanslibre/AveriaSansLibre-LightItalic.ttf",
