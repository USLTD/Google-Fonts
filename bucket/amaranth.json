{
  "autoupdate": {
    "url": [
      "https://raw.githubusercontent.com/google/fonts/main/ofl/amaranth/Amaranth-Regular.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/amaranth/Amaranth-Italic.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/amaranth/Amaranth-Bold.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/amaranth/Amaranth-BoldItalic.ttf"
    ]
  },
  "version": "latest",
  "description": "Amaranth font family designed by Gesine Todt",
  "license": "OFL",
  "installer": {
    "script": [
      "$fontFiles = Get-ChildItem \"$dir\" -Filter \"*.ttf\"",
      "foreach ($file in $fontFiles) {",
      "    New-ItemProperty -Path \"HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts\" -Name $file.Name.Replace($file.Extension, \" (TrueType)\") -Value $file.Name -Force | Out-Null",
      "    Copy-Item $file.FullName -Destination \"$env:windir\\Fonts\" -Force",
      "}"
    ]
  },
  "hash": [
    "49D60587DB044AF5158AFE373BFA6204D8DCCE647CCD4F1F1C61F560980554EC",
