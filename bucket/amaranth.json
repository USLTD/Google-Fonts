    "E8FC151453806C6AAED72A40BACAF3FCF380CCD5D852DE08BD686E55AE70464B"
  ],
  "homepage": "https://fonts.google.com/specimen/Amaranth",
  "url": [
    "https://raw.githubusercontent.com/google/fonts/main/ofl/amaranth/Amaranth-Regular.ttf",
    "https://raw.githubusercontent.com/google/fonts/main/ofl/amaranth/Amaranth-Italic.ttf",
    "https://raw.githubusercontent.com/google/fonts/main/ofl/amaranth/Amaranth-Bold.ttf",
    "https://raw.githubusercontent.com/google/fonts/main/ofl/amaranth/Amaranth-BoldItalic.ttf"
  ],
  "checkver": {
    "url": "https://api.github.com/repos/google/fonts/commits?path=ofl/amaranth&per_page=1",
    "regex": "\"sha\":\\s*\"([a-f0-9]{7})"
  },
  "uninstaller": {
    "script": [
      "$fontFiles = @(\"Amaranth-Regular.ttf\", \"Amaranth-Italic.ttf\", \"Amaranth-Bold.ttf\", \"Amaranth-BoldItalic.ttf\") foreach ($file in $fontFiles) {     $fontName = [System.IO.Path]::GetFileNameWithoutExtension($file)     Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name \"$fontName (TrueType)\" -ErrorAction SilentlyContinue     Remove-Item \"$env:windir\\Fonts\\$file\" -Force -ErrorAction SilentlyContinue }"
    ]
  }
}
