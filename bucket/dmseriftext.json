{
  "autoupdate": {
    "url": [
      "https://raw.githubusercontent.com/google/fonts/main/ofl/dmseriftext/DMSerifText-Regular.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/dmseriftext/DMSerifText-Italic.ttf"
    ]
  },
  "version": "latest",
  "description": "DM Serif Text font family designed by Colophon Foundry",
  "license": "OFL",
  "installer": {
    "script": [
      "$fontFiles = Get-ChildItem \"$dir\" -Filter \"*.ttf\"",
      "foreach ($file in $fontFiles) {",
      "    New-ItemProperty -Path \"HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts\" -Name $file.Name.Replace($file.Extension, \" (TrueType)\") -Value $file.Name -Force | Out-Null",
      "    Copy-Item $file.FullName -Destination \"$env:windir\\Fonts\" -Force",
      "}"
    ]
  },
  "hash": [
    "94B5FA7BAC0F406CB3149512037F37EA21B55CECD732C3FD3A076260441399CD",
    "D016B81DF5CD7462188A0BA11DC343CE2897DFFA39FB1FCFF0FEF0BB7684364E"
  ],
  "homepage": "https://fonts.google.com/specimen/DM+Serif+Text",
  "url": [
    "https://raw.githubusercontent.com/google/fonts/main/ofl/dmseriftext/DMSerifText-Regular.ttf",
    "https://raw.githubusercontent.com/google/fonts/main/ofl/dmseriftext/DMSerifText-Italic.ttf"
  ],
  "checkver": {
    "url": "https://api.github.com/repos/google/fonts/commits?path=ofl/dmseriftext&per_page=1",
    "regex": "\"sha\":\\s*\"([a-f0-9]{7})"
  },
  "uninstaller": {
    "script": [
      "$fontFiles = @(\"DMSerifText-Regular.ttf\", \"DMSerifText-Italic.ttf\") foreach ($file in $fontFiles) {     $fontName = [System.IO.Path]::GetFileNameWithoutExtension($file)     Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name \"$fontName (TrueType)\" -ErrorAction SilentlyContinue     Remove-Item \"$env:windir\\Fonts\\$file\" -Force -ErrorAction SilentlyContinue }"
    ]
  }
}
