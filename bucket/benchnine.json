{
  "autoupdate": {
    "url": [
      "https://raw.githubusercontent.com/google/fonts/main/ofl/benchnine/BenchNine-Light.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/benchnine/BenchNine-Regular.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/benchnine/BenchNine-Bold.ttf"
    ]
  },
  "version": "latest",
  "description": "BenchNine font family designed by Vernon Adams",
  "license": "OFL",
  "installer": {
    "script": [
      "$fontFiles = Get-ChildItem \"$dir\" -Filter \"*.ttf\"",
      "foreach ($file in $fontFiles) {",
      "    New-ItemProperty -Path \"HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts\" -Name $file.Name.Replace($file.Extension, \" (TrueType)\") -Value $file.Name -Force | Out-Null",
      "    Copy-Item $file.FullName -Destination \"$env:windir\\Fonts\" -Force",
      "}"
    ]
  },
  "hash": [
    "B1A0AA5FD59B09AFF1E396FB617C7CA9223C39E1BBBC1199D96784A8CE707878",
    "ABC1E1DFCFCF8FECF322D85BD461F308A68D313AB2A82F4F192D9580A82BB0D7",
    "5D3C445184569F424ED6D434CAD16BDDA130C5A395F79E2674F447CD5495CB97"
  ],
  "homepage": "https://fonts.google.com/specimen/BenchNine",
  "url": [
    "https://raw.githubusercontent.com/google/fonts/main/ofl/benchnine/BenchNine-Light.ttf",
    "https://raw.githubusercontent.com/google/fonts/main/ofl/benchnine/BenchNine-Regular.ttf",
    "https://raw.githubusercontent.com/google/fonts/main/ofl/benchnine/BenchNine-Bold.ttf"
  ],
  "checkver": {
    "url": "https://api.github.com/repos/google/fonts/commits?path=ofl/benchnine&per_page=1",
    "regex": "\"sha\":\\s*\"([a-f0-9]{7})"
  },
  "uninstaller": {
    "script": [
      "$fontFiles = @(\"BenchNine-Light.ttf\", \"BenchNine-Regular.ttf\", \"BenchNine-Bold.ttf\") foreach ($file in $fontFiles) {     $fontName = [System.IO.Path]::GetFileNameWithoutExtension($file)     Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name \"$fontName (TrueType)\" -ErrorAction SilentlyContinue     Remove-Item \"$env:windir\\Fonts\\$file\" -Force -ErrorAction SilentlyContinue }"
    ]
  }
}
