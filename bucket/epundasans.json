{
  "autoupdate": {
    "url": [
      "https://raw.githubusercontent.com/google/fonts/main/ofl/epundasans/EpundaSans[wght].ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/epundasans/EpundaSans-Italic[wght].ttf"
    ]
  },
  "version": "latest",
  "description": "Epunda Sans font family designed by Typofactur",
  "license": "OFL",
  "installer": {
    "script": [
      "$fontFiles = Get-ChildItem \"$dir\" -Filter \"*.ttf\"",
      "foreach ($file in $fontFiles) {",
      "    New-ItemProperty -Path \"HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts\" -Name $file.Name.Replace($file.Extension, \" (TrueType)\") -Value $file.Name -Force | Out-Null",
      "    Copy-Item $file.FullName -Destination \"$env:windir\\Fonts\" -Force",
      "}"
    ]
  },
  "hash": [
    "5B66232F4DA371C82F22C5C4FD50EF99D46C1511E9A23A757E085E3060C2B0C0",
    "1BD18E77526EE85D61C6FAABC64C9DB37455B7709947A38D0FBD25133AE695A8"
  ],
  "homepage": "https://fonts.google.com/specimen/Epunda+Sans",
  "url": [
    "https://raw.githubusercontent.com/google/fonts/main/ofl/epundasans/EpundaSans[wght].ttf",
    "https://raw.githubusercontent.com/google/fonts/main/ofl/epundasans/EpundaSans-Italic[wght].ttf"
  ],
  "checkver": {
    "url": "https://api.github.com/repos/google/fonts/commits?path=ofl/epundasans&per_page=1",
    "regex": "\"sha\":\\s*\"([a-f0-9]{7})"
  },
  "uninstaller": {
    "script": [
      "$fontFiles = @(\"EpundaSans[wght].ttf\", \"EpundaSans-Italic[wght].ttf\") foreach ($file in $fontFiles) {     $fontName = [System.IO.Path]::GetFileNameWithoutExtension($file)     Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name \"$fontName (TrueType)\" -ErrorAction SilentlyContinue     Remove-Item \"$env:windir\\Fonts\\$file\" -Force -ErrorAction SilentlyContinue }"
    ]
  }
}
