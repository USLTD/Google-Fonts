    "75B8835327DB778DA23A029AD0782BDE9F82567F902F9CF0CD1E18EFA0FA96BC",
    "4A5310A8D87F7909FA465794FAB60DC37AAB5EDE8214FF7EEA95F36C7A2B8974"
  ],
  "homepage": "https://fonts.google.com/specimen/Cambay",
  "url": [
    "https://raw.githubusercontent.com/google/fonts/main/ofl/cambay/Cambay-Regular.ttf",
    "https://raw.githubusercontent.com/google/fonts/main/ofl/cambay/Cambay-Italic.ttf",
    "https://raw.githubusercontent.com/google/fonts/main/ofl/cambay/Cambay-Bold.ttf",
    "https://raw.githubusercontent.com/google/fonts/main/ofl/cambay/Cambay-BoldItalic.ttf"
  ],
  "checkver": {
    "url": "https://api.github.com/repos/google/fonts/commits?path=ofl/cambay&per_page=1",
    "regex": "\"sha\":\\s*\"([a-f0-9]{7})"
  },
  "uninstaller": {
    "script": [
      "$fontFiles = @(\"Cambay-Regular.ttf\", \"Cambay-Italic.ttf\", \"Cambay-Bold.ttf\", \"Cambay-BoldItalic.ttf\") foreach ($file in $fontFiles) {     $fontName = [System.IO.Path]::GetFileNameWithoutExtension($file)     Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name \"$fontName (TrueType)\" -ErrorAction SilentlyContinue     Remove-Item \"$env:windir\\Fonts\\$file\" -Force -ErrorAction SilentlyContinue }"
    ]
  }
}
