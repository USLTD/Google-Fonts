  "autoupdate": {
    "url": [
      "https://raw.githubusercontent.com/google/fonts/main/ofl/maitree/Maitree-ExtraLight.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/maitree/Maitree-Light.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/maitree/Maitree-Regular.ttf",
