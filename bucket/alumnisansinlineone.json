{
  "autoupdate": {
    "url": [
      "https://raw.githubusercontent.com/google/fonts/main/ofl/alumnisansinlineone/AlumniSansInlineOne-Regular.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/alumnisansinlineone/AlumniSansInlineOne-Italic.ttf"
    ]
  },
  "version": "latest",
  "description": "Alumni Sans Inline One font family designed by Robert Leuschke",
  "license": "OFL",
  "installer": {
    "script": [
      "$fontFiles = Get-ChildItem \"$dir\" -Filter \"*.ttf\"",
      "foreach ($file in $fontFiles) {",
      "    New-ItemProperty -Path \"HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts\" -Name $file.Name.Replace($file.Extension, \" (TrueType)\") -Value $file.Name -Force | Out-Null",
      "    Copy-Item $file.FullName -Destination \"$env:windir\\Fonts\" -Force",
      "}"
    ]
  },
  "hash": [
    "E77A9DB5E63F9316840CAB59D1364CD40334D6CD441C0B43FE2A18B2521E0E7E",
    "BA98FE1A9AA70F60417851B357882E0275A3F586FF4039C8F258B4AF638171FF"
  ],
  "homepage": "https://fonts.google.com/specimen/Alumni+Sans+Inline+One",
  "url": [
    "https://raw.githubusercontent.com/google/fonts/main/ofl/alumnisansinlineone/AlumniSansInlineOne-Regular.ttf",
    "https://raw.githubusercontent.com/google/fonts/main/ofl/alumnisansinlineone/AlumniSansInlineOne-Italic.ttf"
  ],
  "checkver": {
    "url": "https://api.github.com/repos/google/fonts/commits?path=ofl/alumnisansinlineone&per_page=1",
    "regex": "\"sha\":\\s*\"([a-f0-9]{7})"
  },
  "uninstaller": {
    "script": [
      "$fontFiles = @(\"AlumniSansInlineOne-Regular.ttf\", \"AlumniSansInlineOne-Italic.ttf\") foreach ($file in $fontFiles) {     $fontName = [System.IO.Path]::GetFileNameWithoutExtension($file)     Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name \"$fontName (TrueType)\" -ErrorAction SilentlyContinue     Remove-Item \"$env:windir\\Fonts\\$file\" -Force -ErrorAction SilentlyContinue }"
    ]
  }
}
