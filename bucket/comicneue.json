{
  "autoupdate": {
    "url": [
      "https://raw.githubusercontent.com/google/fonts/main/ofl/comicneue/ComicNeue-Light.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/comicneue/ComicNeue-LightItalic.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/comicneue/ComicNeue-Regular.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/comicneue/ComicNeue-Italic.ttf",
