  },
  "uninstaller": {
    "script": [
      "$fontFiles = @(\"ComicNeue-Light.ttf\", \"ComicNeue-LightItalic.ttf\", \"ComicNeue-Regular.ttf\", \"ComicNeue-Italic.ttf\", \"ComicNeue-Bold.ttf\", \"ComicNeue-BoldItalic.ttf\") foreach ($file in $fontFiles) {     $fontName = [System.IO.Path]::GetFileNameWithoutExtension($file)     Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name \"$fontName (TrueType)\" -ErrorAction SilentlyContinue     Remove-Item \"$env:windir\\Fonts\\$file\" -Force -ErrorAction SilentlyContinue }"
    ]
  }
