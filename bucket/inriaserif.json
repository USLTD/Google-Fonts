  ],
  "autoupdate": {
    "url": [
      "https://raw.githubusercontent.com/google/fonts/main/ofl/inriaserif/InriaSerif-Light.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/inriaserif/InriaSerif-LightItalic.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/inriaserif/InriaSerif-Regular.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/inriaserif/InriaSerif-Italic.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/inriaserif/InriaSerif-Bold.ttf",
