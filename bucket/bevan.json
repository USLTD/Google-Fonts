{
  "autoupdate": {
    "url": [
      "https://raw.githubusercontent.com/google/fonts/main/ofl/bevan/Bevan-Regular.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/bevan/Bevan-Italic.ttf"
    ]
  },
  "version": "latest",
  "description": "Bevan font family designed by Vernon Adams",
  "license": "OFL",
  "installer": {
    "script": [
      "$fontFiles = Get-ChildItem \"$dir\" -Filter \"*.ttf\"",
      "foreach ($file in $fontFiles) {",
      "    New-ItemProperty -Path \"HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts\" -Name $file.Name.Replace($file.Extension, \" (TrueType)\") -Value $file.Name -Force | Out-Null",
      "    Copy-Item $file.FullName -Destination \"$env:windir\\Fonts\" -Force",
      "}"
    ]
  },
  "hash": [
    "8D16C0920330F1DEF84E342CE70626C27FBF179B4294E6391B19301FF5873469",
    "BDF6744E1A398C2BBF80E94A8195209759992B25D09863EEFACC42DE4C9CAF6B"
  ],
  "homepage": "https://fonts.google.com/specimen/Bevan",
  "url": [
    "https://raw.githubusercontent.com/google/fonts/main/ofl/bevan/Bevan-Regular.ttf",
    "https://raw.githubusercontent.com/google/fonts/main/ofl/bevan/Bevan-Italic.ttf"
  ],
  "checkver": {
    "url": "https://api.github.com/repos/google/fonts/commits?path=ofl/bevan&per_page=1",
    "regex": "\"sha\":\\s*\"([a-f0-9]{7})"
  },
  "uninstaller": {
    "script": [
      "$fontFiles = @(\"Bevan-Regular.ttf\", \"Bevan-Italic.ttf\") foreach ($file in $fontFiles) {     $fontName = [System.IO.Path]::GetFileNameWithoutExtension($file)     Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name \"$fontName (TrueType)\" -ErrorAction SilentlyContinue     Remove-Item \"$env:windir\\Fonts\\$file\" -Force -ErrorAction SilentlyContinue }"
    ]
  }
}
