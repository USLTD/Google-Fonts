{
  "autoupdate": {
    "url": [
      "https://raw.githubusercontent.com/google/fonts/main/ofl/amita/Amita-Regular.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/amita/Amita-Bold.ttf"
    ]
  },
  "version": "latest",
  "description": "Amita font family designed by Eduardo Tunni, Brian Bonislawsky",
  "license": "OFL",
  "installer": {
    "script": [
      "$fontFiles = Get-ChildItem \"$dir\" -Filter \"*.ttf\"",
      "foreach ($file in $fontFiles) {",
      "    New-ItemProperty -Path \"HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts\" -Name $file.Name.Replace($file.Extension, \" (TrueType)\") -Value $file.Name -Force | Out-Null",
      "    Copy-Item $file.FullName -Destination \"$env:windir\\Fonts\" -Force",
      "}"
    ]
  },
  "hash": [
    "551369EA6A8CAEAA9D2DC31719564BA2379A445D16E6994BC7ADBF9446A2B63D",
    "2E3DB0A183495CC55B81346311BC2C22DDE0E4B6599A9F8A7469B5FEFFDBF0E8"
  ],
  "homepage": "https://fonts.google.com/specimen/Amita",
  "url": [
    "https://raw.githubusercontent.com/google/fonts/main/ofl/amita/Amita-Regular.ttf",
    "https://raw.githubusercontent.com/google/fonts/main/ofl/amita/Amita-Bold.ttf"
  ],
  "checkver": {
    "url": "https://api.github.com/repos/google/fonts/commits?path=ofl/amita&per_page=1",
    "regex": "\"sha\":\\s*\"([a-f0-9]{7})"
  },
  "uninstaller": {
    "script": [
      "$fontFiles = @(\"Amita-Regular.ttf\", \"Amita-Bold.ttf\") foreach ($file in $fontFiles) {     $fontName = [System.IO.Path]::GetFileNameWithoutExtension($file)     Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name \"$fontName (TrueType)\" -ErrorAction SilentlyContinue     Remove-Item \"$env:windir\\Fonts\\$file\" -Force -ErrorAction SilentlyContinue }"
    ]
  }
}
