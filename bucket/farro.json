{
  "autoupdate": {
    "url": [
      "https://raw.githubusercontent.com/google/fonts/main/ofl/farro/Farro-Light.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/farro/Farro-Regular.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/farro/Farro-Medium.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/farro/Farro-Bold.ttf"
    ]
  },
  "version": "latest",
  "description": "Farro font family designed by Grayscale",
  "license": "OFL",
  "installer": {
    "script": [
      "$fontFiles = Get-ChildItem \"$dir\" -Filter \"*.ttf\"",
      "foreach ($file in $fontFiles) {",
      "    New-ItemProperty -Path \"HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts\" -Name $file.Name.Replace($file.Extension, \" (TrueType)\") -Value $file.Name -Force | Out-Null",
      "    Copy-Item $file.FullName -Destination \"$env:windir\\Fonts\" -Force",
      "}"
    ]
  },
  "hash": [
    "0E66C58243C6F4F7B10EA268B52687C627D658D607493865AEE474ACF2B5D7FB",
    "EED5807E2779C1FBA1A1627A1D34B0450E4FC6A87200522E2F3E3F617221C82B",
    "A5447BF5122E9A9804007C56353653EE7F223008120D428A5176A028EC697C80",
    "7671A5D122D2E303C7ECDBEB0E3CE552EC8AB644484D587E72AC71A06D3D9A07"
  ],
  "homepage": "https://fonts.google.com/specimen/Farro",
  "url": [
    "https://raw.githubusercontent.com/google/fonts/main/ofl/farro/Farro-Light.ttf",
    "https://raw.githubusercontent.com/google/fonts/main/ofl/farro/Farro-Regular.ttf",
    "https://raw.githubusercontent.com/google/fonts/main/ofl/farro/Farro-Medium.ttf",
    "https://raw.githubusercontent.com/google/fonts/main/ofl/farro/Farro-Bold.ttf"
  ],
  "checkver": {
    "url": "https://api.github.com/repos/google/fonts/commits?path=ofl/farro&per_page=1",
    "regex": "\"sha\":\\s*\"([a-f0-9]{7})"
  },
  "uninstaller": {
    "script": [
      "$fontFiles = @(\"Farro-Light.ttf\", \"Farro-Regular.ttf\", \"Farro-Medium.ttf\", \"Farro-Bold.ttf\") foreach ($file in $fontFiles) {     $fontName = [System.IO.Path]::GetFileNameWithoutExtension($file)     Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name \"$fontName (TrueType)\" -ErrorAction SilentlyContinue     Remove-Item \"$env:windir\\Fonts\\$file\" -Force -ErrorAction SilentlyContinue }"
    ]
  }
}
