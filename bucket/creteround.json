{
  "autoupdate": {
    "url": [
      "https://raw.githubusercontent.com/google/fonts/main/ofl/creteround/CreteRound-Regular.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/creteround/CreteRound-Italic.ttf"
    ]
  },
  "version": "latest",
  "description": "Crete Round font family designed by TypeTogether",
  "license": "OFL",
  "installer": {
    "script": [
      "$fontFiles = Get-ChildItem \"$dir\" -Filter \"*.ttf\"",
      "foreach ($file in $fontFiles) {",
      "    New-ItemProperty -Path \"HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts\" -Name $file.Name.Replace($file.Extension, \" (TrueType)\") -Value $file.Name -Force | Out-Null",
      "    Copy-Item $file.FullName -Destination \"$env:windir\\Fonts\" -Force",
      "}"
    ]
  },
  "hash": [
    "2B06EE75C35806B9FAB35E054FBB97AF98FB6B2419C6105697351DC1A2B306C8",
    "EEE412E43D843B89A3170B9C5DBAE2CE5DA95FF729916D3A2C3441AED3411B42"
  ],
  "homepage": "https://fonts.google.com/specimen/Crete+Round",
  "url": [
    "https://raw.githubusercontent.com/google/fonts/main/ofl/creteround/CreteRound-Regular.ttf",
    "https://raw.githubusercontent.com/google/fonts/main/ofl/creteround/CreteRound-Italic.ttf"
  ],
  "checkver": {
    "url": "https://api.github.com/repos/google/fonts/commits?path=ofl/creteround&per_page=1",
    "regex": "\"sha\":\\s*\"([a-f0-9]{7})"
  },
  "uninstaller": {
    "script": [
      "$fontFiles = @(\"CreteRound-Regular.ttf\", \"CreteRound-Italic.ttf\") foreach ($file in $fontFiles) {     $fontName = [System.IO.Path]::GetFileNameWithoutExtension($file)     Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name \"$fontName (TrueType)\" -ErrorAction SilentlyContinue     Remove-Item \"$env:windir\\Fonts\\$file\" -Force -ErrorAction SilentlyContinue }"
    ]
  }
}
