{
  "autoupdate": {
    "url": [
      "https://raw.githubusercontent.com/google/fonts/main/ofl/bodonimodasc/BodoniModaSC[opsz,wght].ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/bodonimodasc/BodoniModaSC-Italic[opsz,wght].ttf"
    ]
  },
  "version": "latest",
  "description": "Bodoni Moda SC font family designed by Owen Earl",
  "license": "OFL",
  "installer": {
    "script": [
      "$fontFiles = Get-ChildItem \"$dir\" -Filter \"*.ttf\"",
      "foreach ($file in $fontFiles) {",
      "    New-ItemProperty -Path \"HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts\" -Name $file.Name.Replace($file.Extension, \" (TrueType)\") -Value $file.Name -Force | Out-Null",
      "    Copy-Item $file.FullName -Destination \"$env:windir\\Fonts\" -Force",
      "}"
    ]
  },
  "hash": [
    "FFF815C5B6FB7DA048ACD9CA59A1B6A5751CF454CB701CD8185A2A0BF06D63EF",
    "303868AEAF81BF6C71CA63AC32669DA9C9DE7F73343E34A18893D3B5E58E672E"
  ],
  "homepage": "https://fonts.google.com/specimen/Bodoni+Moda+SC",
  "url": [
    "https://raw.githubusercontent.com/google/fonts/main/ofl/bodonimodasc/BodoniModaSC[opsz,wght].ttf",
    "https://raw.githubusercontent.com/google/fonts/main/ofl/bodonimodasc/BodoniModaSC-Italic[opsz,wght].ttf"
  ],
  "checkver": {
    "url": "https://api.github.com/repos/google/fonts/commits?path=ofl/bodonimodasc&per_page=1",
    "regex": "\"sha\":\\s*\"([a-f0-9]{7})"
  },
  "uninstaller": {
    "script": [
      "$fontFiles = @(\"BodoniModaSC[opsz,wght].ttf\", \"BodoniModaSC-Italic[opsz,wght].ttf\") foreach ($file in $fontFiles) {     $fontName = [System.IO.Path]::GetFileNameWithoutExtension($file)     Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name \"$fontName (TrueType)\" -ErrorAction SilentlyContinue     Remove-Item \"$env:windir\\Fonts\\$file\" -Force -ErrorAction SilentlyContinue }"
    ]
  }
}
