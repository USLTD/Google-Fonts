  "autoupdate": {
    "url": [
      "https://raw.githubusercontent.com/google/fonts/main/ofl/mitr/Mitr-ExtraLight.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/mitr/Mitr-Light.ttf",
