{
  "autoupdate": {
    "url": [
      "https://raw.githubusercontent.com/google/fonts/main/ofl/catamaran/Catamaran[wght].ttf"
    ]
  },
  "version": "latest",
  "description": "Catamaran font family designed by Pria Ravichandran",
  "license": "OFL",
  "installer": {
    "script": [
      "$fontFiles = Get-ChildItem \"$dir\" -Filter \"*.ttf\"",
      "foreach ($file in $fontFiles) {",
      "    New-ItemProperty -Path \"HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts\" -Name $file.Name.Replace($file.Extension, \" (TrueType)\") -Value $file.Name -Force | Out-Null",
      "    Copy-Item $file.FullName -Destination \"$env:windir\\Fonts\" -Force",
      "}"
    ]
  },
  "hash": [
    "F6EE331C381F441454225196D7930D4D0A31554D7F1F9C8C58149CA9E122B294"
  ],
  "homepage": "https://fonts.google.com/specimen/Catamaran",
  "url": [
    "https://raw.githubusercontent.com/google/fonts/main/ofl/catamaran/Catamaran[wght].ttf"
  ],
  "checkver": {
    "url": "https://api.github.com/repos/google/fonts/commits?path=ofl/catamaran&per_page=1",
    "regex": "\"sha\":\\s*\"([a-f0-9]{7})"
  },
  "uninstaller": {
    "script": [
      "$fontFiles = @(\"Catamaran[wght].ttf\") foreach ($file in $fontFiles) {     $fontName = [System.IO.Path]::GetFileNameWithoutExtension($file)     Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name \"$fontName (TrueType)\" -ErrorAction SilentlyContinue     Remove-Item \"$env:windir\\Fonts\\$file\" -Force -ErrorAction SilentlyContinue }"
    ]
  }
}
