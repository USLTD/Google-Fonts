{
  "autoupdate": {
    "url": [
      "https://raw.githubusercontent.com/google/fonts/main/ofl/asap/Asap[wdth,wght].ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/asap/Asap-Italic[wdth,wght].ttf"
    ]
  },
  "version": "latest",
  "description": "Asap font family designed by Omnibus-Type",
  "license": "OFL",
  "installer": {
    "script": [
      "$fontFiles = Get-ChildItem \"$dir\" -Filter \"*.ttf\"",
      "foreach ($file in $fontFiles) {",
      "    New-ItemProperty -Path \"HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts\" -Name $file.Name.Replace($file.Extension, \" (TrueType)\") -Value $file.Name -Force | Out-Null",
      "    Copy-Item $file.FullName -Destination \"$env:windir\\Fonts\" -Force",
      "}"
    ]
  },
  "hash": [
    "7BF29BCAB72F7D00DE600E964A3FC206620050D8448DDD976822378D0FE18028",
    "A21E12F9BABF2D02526003B27DFF884B6D1CD0FED883FFE7740725626A11DD59"
  ],
  "homepage": "https://fonts.google.com/specimen/Asap",
  "url": [
    "https://raw.githubusercontent.com/google/fonts/main/ofl/asap/Asap[wdth,wght].ttf",
    "https://raw.githubusercontent.com/google/fonts/main/ofl/asap/Asap-Italic[wdth,wght].ttf"
  ],
  "checkver": {
    "url": "https://api.github.com/repos/google/fonts/commits?path=ofl/asap&per_page=1",
    "regex": "\"sha\":\\s*\"([a-f0-9]{7})"
  },
  "uninstaller": {
    "script": [
      "$fontFiles = @(\"Asap[wdth,wght].ttf\", \"Asap-Italic[wdth,wght].ttf\") foreach ($file in $fontFiles) {     $fontName = [System.IO.Path]::GetFileNameWithoutExtension($file)     Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name \"$fontName (TrueType)\" -ErrorAction SilentlyContinue     Remove-Item \"$env:windir\\Fonts\\$file\" -Force -ErrorAction SilentlyContinue }"
    ]
  }
}
