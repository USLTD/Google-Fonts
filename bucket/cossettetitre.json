{
  "autoupdate": {
    "url": [
      "https://raw.githubusercontent.com/google/fonts/main/ofl/cossettetitre/CossetteTitre-Regular.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/cossettetitre/CossetteTitre-Bold.ttf"
    ]
  },
  "version": "latest",
  "description": "Cossette Titre font family designed by Cossette",
  "license": "OFL",
  "installer": {
    "script": [
      "$fontFiles = Get-ChildItem \"$dir\" -Filter \"*.ttf\"",
      "foreach ($file in $fontFiles) {",
      "    New-ItemProperty -Path \"HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts\" -Name $file.Name.Replace($file.Extension, \" (TrueType)\") -Value $file.Name -Force | Out-Null",
      "    Copy-Item $file.FullName -Destination \"$env:windir\\Fonts\" -Force",
      "}"
    ]
  },
  "hash": [
    "552EE5848F2AFD5ABDF52F6EC7896A4AA443AAADD68FA5D5048E5788F0850F00",
    "05635008898DD896DF9DA3DAF04312E22BA59DB5774BC091DC2680A20CA571BB"
  ],
  "homepage": "https://fonts.google.com/specimen/Cossette+Titre",
  "url": [
    "https://raw.githubusercontent.com/google/fonts/main/ofl/cossettetitre/CossetteTitre-Regular.ttf",
    "https://raw.githubusercontent.com/google/fonts/main/ofl/cossettetitre/CossetteTitre-Bold.ttf"
  ],
  "checkver": {
    "url": "https://api.github.com/repos/google/fonts/commits?path=ofl/cossettetitre&per_page=1",
    "regex": "\"sha\":\\s*\"([a-f0-9]{7})"
  },
  "uninstaller": {
    "script": [
      "$fontFiles = @(\"CossetteTitre-Regular.ttf\", \"CossetteTitre-Bold.ttf\") foreach ($file in $fontFiles) {     $fontName = [System.IO.Path]::GetFileNameWithoutExtension($file)     Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name \"$fontName (TrueType)\" -ErrorAction SilentlyContinue     Remove-Item \"$env:windir\\Fonts\\$file\" -Force -ErrorAction SilentlyContinue }"
    ]
  }
}
