  "uninstaller": {
    "script": [
      "$fontFiles = @(\"BioRhymeExpanded-ExtraLight.ttf\", \"BioRhymeExpanded-Light.ttf\", \"BioRhymeExpanded-Regular.ttf\", \"BioRhymeExpanded-Bold.ttf\", \"BioRhymeExpanded-ExtraBold.ttf\") foreach ($file in $fontFiles) {     $fontName = [System.IO.Path]::GetFileNameWithoutExtension($file)     Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name \"$fontName (TrueType)\" -ErrorAction SilentlyContinue     Remove-Item \"$env:windir\\Fonts\\$file\" -Force -ErrorAction SilentlyContinue }"
    ]
