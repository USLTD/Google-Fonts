{
  "autoupdate": {
    "url": [
      "https://raw.githubusercontent.com/google/fonts/main/ofl/finlandica/Finlandica[wght].ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/finlandica/Finlandica-Italic[wght].ttf"
    ]
  },
  "version": "latest",
  "description": "Finlandica font family designed by Helsinki Type Studio, Niklas Ekholm, Juho Hiilivirta, Jaakko Suomalainen",
  "license": "OFL",
  "installer": {
    "script": [
      "$fontFiles = Get-ChildItem \"$dir\" -Filter \"*.ttf\"",
      "foreach ($file in $fontFiles) {",
      "    New-ItemProperty -Path \"HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts\" -Name $file.Name.Replace($file.Extension, \" (TrueType)\") -Value $file.Name -Force | Out-Null",
      "    Copy-Item $file.FullName -Destination \"$env:windir\\Fonts\" -Force",
      "}"
    ]
  },
  "hash": [
    "8192C7F916AD929890B799BD4FE0974200BE62E024C267C7B234632CACA6658E",
    "70B7BDDB5B5D01AEB8461E5A4C0D022EFBC892AD96F68EB7D163CB3440360725"
  ],
  "homepage": "https://fonts.google.com/specimen/Finlandica",
  "url": [
    "https://raw.githubusercontent.com/google/fonts/main/ofl/finlandica/Finlandica[wght].ttf",
    "https://raw.githubusercontent.com/google/fonts/main/ofl/finlandica/Finlandica-Italic[wght].ttf"
  ],
  "checkver": {
    "url": "https://api.github.com/repos/google/fonts/commits?path=ofl/finlandica&per_page=1",
    "regex": "\"sha\":\\s*\"([a-f0-9]{7})"
  },
  "uninstaller": {
    "script": [
      "$fontFiles = @(\"Finlandica[wght].ttf\", \"Finlandica-Italic[wght].ttf\") foreach ($file in $fontFiles) {     $fontName = [System.IO.Path]::GetFileNameWithoutExtension($file)     Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name \"$fontName (TrueType)\" -ErrorAction SilentlyContinue     Remove-Item \"$env:windir\\Fonts\\$file\" -Force -ErrorAction SilentlyContinue }"
    ]
  }
}
