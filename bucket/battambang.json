{
  "autoupdate": {
    "url": [
      "https://raw.githubusercontent.com/google/fonts/main/ofl/battambang/Battambang-Thin.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/battambang/Battambang-Light.ttf",
