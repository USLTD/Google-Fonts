  "uninstaller": {
    "script": [
      "$fontFiles = @(\"Battambang-Thin.ttf\", \"Battambang-Light.ttf\", \"Battambang-Regular.ttf\", \"Battambang-Bold.ttf\", \"Battambang-Black.ttf\") foreach ($file in $fontFiles) {     $fontName = [System.IO.Path]::GetFileNameWithoutExtension($file)     Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name \"$fontName (TrueType)\" -ErrorAction SilentlyContinue     Remove-Item \"$env:windir\\Fonts\\$file\" -Force -ErrorAction SilentlyContinue }"
    ]
  }
