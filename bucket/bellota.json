  "uninstaller": {
    "script": [
      "$fontFiles = @(\"Bellota-Light.ttf\", \"Bellota-LightItalic.ttf\", \"Bellota-Regular.ttf\", \"Bellota-Italic.ttf\", \"Bellota-Bold.ttf\", \"Bellota-BoldItalic.ttf\") foreach ($file in $fontFiles) {     $fontName = [System.IO.Path]::GetFileNameWithoutExtension($file)     Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name \"$fontName (TrueType)\" -ErrorAction SilentlyContinue     Remove-Item \"$env:windir\\Fonts\\$file\" -Force -ErrorAction SilentlyContinue }"
