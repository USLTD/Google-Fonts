{
  "autoupdate": {
    "url": [
      "https://raw.githubusercontent.com/google/fonts/main/ofl/albertsans/AlbertSans[wght].ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/albertsans/AlbertSans-Italic[wght].ttf"
    ]
  },
  "version": "latest",
  "description": "Albert Sans font family designed by Andreas Rasmussen",
  "license": "OFL",
  "installer": {
    "script": [
      "$fontFiles = Get-ChildItem \"$dir\" -Filter \"*.ttf\"",
      "foreach ($file in $fontFiles) {",
      "    New-ItemProperty -Path \"HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts\" -Name $file.Name.Replace($file.Extension, \" (TrueType)\") -Value $file.Name -Force | Out-Null",
      "    Copy-Item $file.FullName -Destination \"$env:windir\\Fonts\" -Force",
      "}"
    ]
  },
  "hash": [
    "8FE5D4CF5822D7096D4D17AD781C90F97C745AC13A22BE619DB74966FBA45FDA",
    "16EB3291F7389045E90A00ABB66A3D2BCA1D03387B7EBBBC2B0CD9A094F86226"
  ],
  "homepage": "https://fonts.google.com/specimen/Albert+Sans",
  "url": [
    "https://raw.githubusercontent.com/google/fonts/main/ofl/albertsans/AlbertSans[wght].ttf",
    "https://raw.githubusercontent.com/google/fonts/main/ofl/albertsans/AlbertSans-Italic[wght].ttf"
  ],
  "checkver": {
    "url": "https://api.github.com/repos/google/fonts/commits?path=ofl/albertsans&per_page=1",
    "regex": "\"sha\":\\s*\"([a-f0-9]{7})"
  },
  "uninstaller": {
    "script": [
      "$fontFiles = @(\"AlbertSans[wght].ttf\", \"AlbertSans-Italic[wght].ttf\") foreach ($file in $fontFiles) {     $fontName = [System.IO.Path]::GetFileNameWithoutExtension($file)     Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name \"$fontName (TrueType)\" -ErrorAction SilentlyContinue     Remove-Item \"$env:windir\\Fonts\\$file\" -Force -ErrorAction SilentlyContinue }"
    ]
  }
}
