  "uninstaller": {
    "script": [
      "$fontFiles = @(\"AveriaSerifLibre-Light.ttf\", \"AveriaSerifLibre-LightItalic.ttf\", \"AveriaSerifLibre-Regular.ttf\", \"AveriaSerifLibre-Italic.ttf\", \"AveriaSerifLibre-Bold.ttf\", \"AveriaSerifLibre-BoldItalic.ttf\") foreach ($file in $fontFiles) {     $fontName = [System.IO.Path]::GetFileNameWithoutExtension($file)     Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name \"$fontName (TrueType)\" -ErrorAction SilentlyContinue     Remove-Item \"$env:windir\\Fonts\\$file\" -Force -ErrorAction SilentlyContinue }"
