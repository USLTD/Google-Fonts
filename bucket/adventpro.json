{
  "autoupdate": {
    "url": [
      "https://raw.githubusercontent.com/google/fonts/main/ofl/adventpro/AdventPro[wdth,wght].ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/adventpro/AdventPro-Italic[wdth,wght].ttf"
    ]
  },
  "version": "latest",
  "description": "Advent Pro font family designed by VivaRado",
  "license": "OFL",
  "installer": {
    "script": [
      "$fontFiles = Get-ChildItem \"$dir\" -Filter \"*.ttf\"",
      "foreach ($file in $fontFiles) {",
      "    New-ItemProperty -Path \"HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts\" -Name $file.Name.Replace($file.Extension, \" (TrueType)\") -Value $file.Name -Force | Out-Null",
      "    Copy-Item $file.FullName -Destination \"$env:windir\\Fonts\" -Force",
      "}"
    ]
  },
  "hash": [
    "B60AB2920B89BDC4B7DADFB282CADAC6E03833E7A80844F9EAC096359B2B9766",
    "0917A5D65589025F2A752B1B0568F924DAC49A065A25B4D60116B3C6D4D9EBAE"
  ],
  "homepage": "https://fonts.google.com/specimen/Advent+Pro",
  "url": [
    "https://raw.githubusercontent.com/google/fonts/main/ofl/adventpro/AdventPro[wdth,wght].ttf",
    "https://raw.githubusercontent.com/google/fonts/main/ofl/adventpro/AdventPro-Italic[wdth,wght].ttf"
  ],
  "checkver": {
    "url": "https://api.github.com/repos/google/fonts/commits?path=ofl/adventpro&per_page=1",
    "regex": "\"sha\":\\s*\"([a-f0-9]{7})"
  },
  "uninstaller": {
    "script": [
      "$fontFiles = @(\"AdventPro[wdth,wght].ttf\", \"AdventPro-Italic[wdth,wght].ttf\") foreach ($file in $fontFiles) {     $fontName = [System.IO.Path]::GetFileNameWithoutExtension($file)     Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name \"$fontName (TrueType)\" -ErrorAction SilentlyContinue     Remove-Item \"$env:windir\\Fonts\\$file\" -Force -ErrorAction SilentlyContinue }"
    ]
  }
}
