      "https://raw.githubusercontent.com/google/fonts/main/ofl/hindkochi/HindKochi-Regular.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/hindkochi/HindKochi-Medium.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/hindkochi/HindKochi-SemiBold.ttf",
