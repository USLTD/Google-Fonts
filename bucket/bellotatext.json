  "uninstaller": {
    "script": [
      "$fontFiles = @(\"BellotaText-Light.ttf\", \"BellotaText-LightItalic.ttf\", \"BellotaText-Regular.ttf\", \"BellotaText-Italic.ttf\", \"BellotaText-Bold.ttf\", \"BellotaText-BoldItalic.ttf\") foreach ($file in $fontFiles) {     $fontName = [System.IO.Path]::GetFileNameWithoutExtension($file)     Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name \"$fontName (TrueType)\" -ErrorAction SilentlyContinue     Remove-Item \"$env:windir\\Fonts\\$file\" -Force -ErrorAction SilentlyContinue }"
    ]
