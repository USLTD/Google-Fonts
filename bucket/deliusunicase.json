{
  "autoupdate": {
    "url": [
      "https://raw.githubusercontent.com/google/fonts/main/ofl/deliusunicase/DeliusUnicase-Regular.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/deliusunicase/DeliusUnicase-Bold.ttf"
    ]
  },
  "version": "latest",
  "description": "Delius Unicase font family designed by Natalia Raices",
  "license": "OFL",
  "installer": {
    "script": [
      "$fontFiles = Get-ChildItem \"$dir\" -Filter \"*.ttf\"",
      "foreach ($file in $fontFiles) {",
      "    New-ItemProperty -Path \"HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts\" -Name $file.Name.Replace($file.Extension, \" (TrueType)\") -Value $file.Name -Force | Out-Null",
      "    Copy-Item $file.FullName -Destination \"$env:windir\\Fonts\" -Force",
      "}"
    ]
  },
  "hash": [
    "26FB53B7297281E4907DFE254CC23C206F28510F683EB726E5C5024CA36DC95D",
    "2FC8F72A7257D837A5B710A8F6CA9E6B7A179F809243EEF9380BA2185B8C2A67"
  ],
  "homepage": "https://fonts.google.com/specimen/Delius+Unicase",
  "url": [
    "https://raw.githubusercontent.com/google/fonts/main/ofl/deliusunicase/DeliusUnicase-Regular.ttf",
    "https://raw.githubusercontent.com/google/fonts/main/ofl/deliusunicase/DeliusUnicase-Bold.ttf"
  ],
  "checkver": {
    "url": "https://api.github.com/repos/google/fonts/commits?path=ofl/deliusunicase&per_page=1",
    "regex": "\"sha\":\\s*\"([a-f0-9]{7})"
  },
  "uninstaller": {
    "script": [
      "$fontFiles = @(\"DeliusUnicase-Regular.ttf\", \"DeliusUnicase-Bold.ttf\") foreach ($file in $fontFiles) {     $fontName = [System.IO.Path]::GetFileNameWithoutExtension($file)     Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name \"$fontName (TrueType)\" -ErrorAction SilentlyContinue     Remove-Item \"$env:windir\\Fonts\\$file\" -Force -ErrorAction SilentlyContinue }"
    ]
  }
}
