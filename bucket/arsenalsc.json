{
  "autoupdate": {
    "url": [
      "https://raw.githubusercontent.com/google/fonts/main/ofl/arsenalsc/ArsenalSC-Regular.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/arsenalsc/ArsenalSC-Italic.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/arsenalsc/ArsenalSC-Bold.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/arsenalsc/ArsenalSC-BoldItalic.ttf"
    ]
  },
  "version": "latest",
  "description": "Arsenal SC font family designed by Andrij Shevchenko",
  "license": "OFL",
  "installer": {
    "script": [
      "$fontFiles = Get-ChildItem \"$dir\" -Filter \"*.ttf\"",
      "foreach ($file in $fontFiles) {",
      "    New-ItemProperty -Path \"HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts\" -Name $file.Name.Replace($file.Extension, \" (TrueType)\") -Value $file.Name -Force | Out-Null",
      "    Copy-Item $file.FullName -Destination \"$env:windir\\Fonts\" -Force",
      "}"
    ]
  },
  "hash": [
    "56D7AE5099045E6B04A963156F665ABEB5CFEC2B55AF0DDEC74AF6564BC7AF47",
    "E384E807DDD1888DB1AE39FB96DF3065E224B6D975DBEF972E6697A7249547EF",
    "A06DAE429DE1FFD9DE35B290BD0BC2CAFC6E542390B118AB95F5414D2D99414B",
    "F2E9FC066073BFF6DBF4B99AF102E9F303ABAB11886665DF0346FFB3C54B090B"
  ],
  "homepage": "https://fonts.google.com/specimen/Arsenal+SC",
  "url": [
    "https://raw.githubusercontent.com/google/fonts/main/ofl/arsenalsc/ArsenalSC-Regular.ttf",
    "https://raw.githubusercontent.com/google/fonts/main/ofl/arsenalsc/ArsenalSC-Italic.ttf",
    "https://raw.githubusercontent.com/google/fonts/main/ofl/arsenalsc/ArsenalSC-Bold.ttf",
    "https://raw.githubusercontent.com/google/fonts/main/ofl/arsenalsc/ArsenalSC-BoldItalic.ttf"
  ],
  "checkver": {
    "url": "https://api.github.com/repos/google/fonts/commits?path=ofl/arsenalsc&per_page=1",
    "regex": "\"sha\":\\s*\"([a-f0-9]{7})"
  },
  "uninstaller": {
    "script": [
      "$fontFiles = @(\"ArsenalSC-Regular.ttf\", \"ArsenalSC-Italic.ttf\", \"ArsenalSC-Bold.ttf\", \"ArsenalSC-BoldItalic.ttf\") foreach ($file in $fontFiles) {     $fontName = [System.IO.Path]::GetFileNameWithoutExtension($file)     Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name \"$fontName (TrueType)\" -ErrorAction SilentlyContinue     Remove-Item \"$env:windir\\Fonts\\$file\" -Force -ErrorAction SilentlyContinue }"
    ]
  }
}
