{
  "autoupdate": {
    "url": [
      "https://raw.githubusercontent.com/google/fonts/main/ofl/castoro/Castoro-Regular.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/castoro/Castoro-Italic.ttf"
    ]
  },
  "version": "latest",
  "description": "Castoro font family designed by Tiro Typeworks, John Hudson, Paul Hanslow, Kaja Słojewska",
  "license": "OFL",
  "installer": {
    "script": [
      "$fontFiles = Get-ChildItem \"$dir\" -Filter \"*.ttf\"",
      "foreach ($file in $fontFiles) {",
      "    New-ItemProperty -Path \"HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts\" -Name $file.Name.Replace($file.Extension, \" (TrueType)\") -Value $file.Name -Force | Out-Null",
      "    Copy-Item $file.FullName -Destination \"$env:windir\\Fonts\" -Force",
      "}"
    ]
  },
  "hash": [
    "9AF87F7DB6AB1DA918C0B0312BEA5F4349782F1397B541A1D0FB2FC4EE35AEAD",
    "802FEA3A19B819C1B2705EF3C1C0BFF3B8E37F832E40DA1D2E6932D733F99FCC"
  ],
  "homepage": "https://fonts.google.com/specimen/Castoro",
  "url": [
    "https://raw.githubusercontent.com/google/fonts/main/ofl/castoro/Castoro-Regular.ttf",
    "https://raw.githubusercontent.com/google/fonts/main/ofl/castoro/Castoro-Italic.ttf"
  ],
  "checkver": {
    "url": "https://api.github.com/repos/google/fonts/commits?path=ofl/castoro&per_page=1",
    "regex": "\"sha\":\\s*\"([a-f0-9]{7})"
  },
  "uninstaller": {
    "script": [
      "$fontFiles = @(\"Castoro-Regular.ttf\", \"Castoro-Italic.ttf\") foreach ($file in $fontFiles) {     $fontName = [System.IO.Path]::GetFileNameWithoutExtension($file)     Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name \"$fontName (TrueType)\" -ErrorAction SilentlyContinue     Remove-Item \"$env:windir\\Fonts\\$file\" -Force -ErrorAction SilentlyContinue }"
    ]
  }
}
