  },
  "uninstaller": {
    "script": [
      "$fontFiles = @(\"AbhayaLibre-Regular.ttf\", \"AbhayaLibre-Medium.ttf\", \"AbhayaLibre-SemiBold.ttf\", \"AbhayaLibre-Bold.ttf\", \"AbhayaLibre-ExtraBold.ttf\") foreach ($file in $fontFiles) {     $fontName = [System.IO.Path]::GetFileNameWithoutExtension($file)     Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name \"$fontName (TrueType)\" -ErrorAction SilentlyContinue     Remove-Item \"$env:windir\\Fonts\\$file\" -Force -ErrorAction SilentlyContinue }"
    ]
  }
