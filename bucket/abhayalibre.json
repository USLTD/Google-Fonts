{
  "autoupdate": {
    "url": [
      "https://raw.githubusercontent.com/google/fonts/main/ofl/abhayalibre/AbhayaLibre-Regular.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/abhayalibre/AbhayaLibre-Medium.ttf",
