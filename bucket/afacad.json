{
  "autoupdate": {
    "url": [
      "https://raw.githubusercontent.com/google/fonts/main/ofl/afacad/Afacad[wght].ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/afacad/Afacad-Italic[wght].ttf"
    ]
  },
  "version": "latest",
  "description": "Afacad font family designed by Kristian Möller, Dicotype",
  "license": "OFL",
  "installer": {
    "script": [
      "$fontFiles = Get-ChildItem \"$dir\" -Filter \"*.ttf\"",
      "foreach ($file in $fontFiles) {",
      "    New-ItemProperty -Path \"HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts\" -Name $file.Name.Replace($file.Extension, \" (TrueType)\") -Value $file.Name -Force | Out-Null",
      "    Copy-Item $file.FullName -Destination \"$env:windir\\Fonts\" -Force",
      "}"
    ]
  },
  "hash": [
    "89513FC375CAFEECCA81110F6A3EF5882D7AC2D871A365B6C93BBFA6039B8230",
    "1CF0A5853330267433C0A1603E239FF33E5963887EC2545C96A1516CA960A717"
  ],
  "homepage": "https://fonts.google.com/specimen/Afacad",
  "url": [
    "https://raw.githubusercontent.com/google/fonts/main/ofl/afacad/Afacad[wght].ttf",
    "https://raw.githubusercontent.com/google/fonts/main/ofl/afacad/Afacad-Italic[wght].ttf"
  ],
  "checkver": {
    "url": "https://api.github.com/repos/google/fonts/commits?path=ofl/afacad&per_page=1",
    "regex": "\"sha\":\\s*\"([a-f0-9]{7})"
  },
  "uninstaller": {
    "script": [
      "$fontFiles = @(\"Afacad[wght].ttf\", \"Afacad-Italic[wght].ttf\") foreach ($file in $fontFiles) {     $fontName = [System.IO.Path]::GetFileNameWithoutExtension($file)     Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name \"$fontName (TrueType)\" -ErrorAction SilentlyContinue     Remove-Item \"$env:windir\\Fonts\\$file\" -Force -ErrorAction SilentlyContinue }"
    ]
  }
}
