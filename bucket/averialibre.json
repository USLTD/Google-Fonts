  "uninstaller": {
    "script": [
      "$fontFiles = @(\"AveriaLibre-Light.ttf\", \"AveriaLibre-LightItalic.ttf\", \"AveriaLibre-Regular.ttf\", \"AveriaLibre-Italic.ttf\", \"AveriaLibre-Bold.ttf\", \"AveriaLibre-BoldItalic.ttf\") foreach ($file in $fontFiles) {     $fontName = [System.IO.Path]::GetFileNameWithoutExtension($file)     Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name \"$fontName (TrueType)\" -ErrorAction SilentlyContinue     Remove-Item \"$env:windir\\Fonts\\$file\" -Force -ErrorAction SilentlyContinue }"
    ]
