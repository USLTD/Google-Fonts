{
  "autoupdate": {
    "url": [
      "https://raw.githubusercontent.com/google/fonts/main/ofl/corben/Corben-Regular.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/corben/Corben-Bold.ttf"
    ]
  },
  "version": "latest",
  "description": "Corben font family designed by Vernon Adams",
  "license": "OFL",
  "installer": {
    "script": [
      "$fontFiles = Get-ChildItem \"$dir\" -Filter \"*.ttf\"",
      "foreach ($file in $fontFiles) {",
      "    New-ItemProperty -Path \"HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts\" -Name $file.Name.Replace($file.Extension, \" (TrueType)\") -Value $file.Name -Force | Out-Null",
      "    Copy-Item $file.FullName -Destination \"$env:windir\\Fonts\" -Force",
      "}"
    ]
  },
  "hash": [
    "DD2C2697A8F936A43B5F0A2BAE1BC82CDAF40F8A5FC1D15C1ECD562B3EA16044",
    "1FB5959682B89680467AB628E2F1E6359C6062ACBB7EDCEA14FFCCA1124DB0F1"
  ],
  "homepage": "https://fonts.google.com/specimen/Corben",
  "url": [
    "https://raw.githubusercontent.com/google/fonts/main/ofl/corben/Corben-Regular.ttf",
    "https://raw.githubusercontent.com/google/fonts/main/ofl/corben/Corben-Bold.ttf"
  ],
  "checkver": {
    "url": "https://api.github.com/repos/google/fonts/commits?path=ofl/corben&per_page=1",
    "regex": "\"sha\":\\s*\"([a-f0-9]{7})"
  },
  "uninstaller": {
    "script": [
      "$fontFiles = @(\"Corben-Regular.ttf\", \"Corben-Bold.ttf\") foreach ($file in $fontFiles) {     $fontName = [System.IO.Path]::GetFileNameWithoutExtension($file)     Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name \"$fontName (TrueType)\" -ErrorAction SilentlyContinue     Remove-Item \"$env:windir\\Fonts\\$file\" -Force -ErrorAction SilentlyContinue }"
    ]
  }
}
