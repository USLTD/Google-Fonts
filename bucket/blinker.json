      "$fontFiles = @(\"Blinker-Thin.ttf\", \"Blinker-ExtraLight.ttf\", \"Blinker-Light.ttf\", \"Blinker-Regular.ttf\", \"Blinker-SemiBold.ttf\", \"Blinker-Bold.ttf\", \"Blinker-ExtraBold.ttf\", \"Blinker-Black.ttf\") foreach ($file in $fontFiles) {     $fontName = [System.IO.Path]::GetFileNameWithoutExtension($file)     Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name \"$fontName (TrueType)\" -ErrorAction SilentlyContinue     Remove-Item \"$env:windir\\Fonts\\$file\" -Force -ErrorAction SilentlyContinue }"
