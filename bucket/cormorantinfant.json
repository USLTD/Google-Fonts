{
  "autoupdate": {
    "url": [
      "https://raw.githubusercontent.com/google/fonts/main/ofl/cormorantinfant/CormorantInfant[wght].ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/cormorantinfant/CormorantInfant-Italic[wght].ttf"
    ]
  },
  "version": "latest",
  "description": "Cormorant Infant font family designed by Christian Thalmann",
  "license": "OFL",
  "installer": {
    "script": [
      "$fontFiles = Get-ChildItem \"$dir\" -Filter \"*.ttf\"",
      "foreach ($file in $fontFiles) {",
      "    New-ItemProperty -Path \"HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts\" -Name $file.Name.Replace($file.Extension, \" (TrueType)\") -Value $file.Name -Force | Out-Null",
      "    Copy-Item $file.FullName -Destination \"$env:windir\\Fonts\" -Force",
      "}"
    ]
  },
  "hash": [
    "48C6EFE07539C75D3108795467898706A9CD71CE876D461E45F58482156D7BF3",
    "D5F81EDEF82CF31C093D057709E1BFB42AA776AACF78651B14F9817C2DECB251"
  ],
  "homepage": "https://fonts.google.com/specimen/Cormorant+Infant",
  "url": [
    "https://raw.githubusercontent.com/google/fonts/main/ofl/cormorantinfant/CormorantInfant[wght].ttf",
    "https://raw.githubusercontent.com/google/fonts/main/ofl/cormorantinfant/CormorantInfant-Italic[wght].ttf"
  ],
  "checkver": {
    "url": "https://api.github.com/repos/google/fonts/commits?path=ofl/cormorantinfant&per_page=1",
    "regex": "\"sha\":\\s*\"([a-f0-9]{7})"
  },
  "uninstaller": {
    "script": [
      "$fontFiles = @(\"CormorantInfant[wght].ttf\", \"CormorantInfant-Italic[wght].ttf\") foreach ($file in $fontFiles) {     $fontName = [System.IO.Path]::GetFileNameWithoutExtension($file)     Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name \"$fontName (TrueType)\" -ErrorAction SilentlyContinue     Remove-Item \"$env:windir\\Fonts\\$file\" -Force -ErrorAction SilentlyContinue }"
    ]
  }
}
