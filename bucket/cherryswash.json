{
  "autoupdate": {
    "url": [
      "https://raw.githubusercontent.com/google/fonts/main/ofl/cherryswash/CherrySwash-Regular.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/cherryswash/CherrySwash-Bold.ttf"
    ]
  },
  "version": "latest",
  "description": "Cherry Swash font family designed by Nataliya Kasatkina",
  "license": "OFL",
  "installer": {
    "script": [
      "$fontFiles = Get-ChildItem \"$dir\" -Filter \"*.ttf\"",
      "foreach ($file in $fontFiles) {",
      "    New-ItemProperty -Path \"HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts\" -Name $file.Name.Replace($file.Extension, \" (TrueType)\") -Value $file.Name -Force | Out-Null",
      "    Copy-Item $file.FullName -Destination \"$env:windir\\Fonts\" -Force",
      "}"
    ]
  },
  "hash": [
    "CE98243D428163BE0D59FC02D3133507CD5AFE78C501AA320C09C5DEAA78A4A3",
    "5CCA323C29A80E19400A06BE7C0C46E19DB8FF2966CBBFF7E05EAC33354124BA"
  ],
  "homepage": "https://fonts.google.com/specimen/Cherry+Swash",
  "url": [
    "https://raw.githubusercontent.com/google/fonts/main/ofl/cherryswash/CherrySwash-Regular.ttf",
    "https://raw.githubusercontent.com/google/fonts/main/ofl/cherryswash/CherrySwash-Bold.ttf"
  ],
  "checkver": {
    "url": "https://api.github.com/repos/google/fonts/commits?path=ofl/cherryswash&per_page=1",
    "regex": "\"sha\":\\s*\"([a-f0-9]{7})"
  },
  "uninstaller": {
    "script": [
      "$fontFiles = @(\"CherrySwash-Regular.ttf\", \"CherrySwash-Bold.ttf\") foreach ($file in $fontFiles) {     $fontName = [System.IO.Path]::GetFileNameWithoutExtension($file)     Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name \"$fontName (TrueType)\" -ErrorAction SilentlyContinue     Remove-Item \"$env:windir\\Fonts\\$file\" -Force -ErrorAction SilentlyContinue }"
    ]
  }
}
