  },
  "uninstaller": {
    "script": [
      "$fontFiles = @(\"CormorantUnicase-Light.ttf\", \"CormorantUnicase-Regular.ttf\", \"CormorantUnicase-Medium.ttf\", \"CormorantUnicase-SemiBold.ttf\", \"CormorantUnicase-Bold.ttf\") foreach ($file in $fontFiles) {     $fontName = [System.IO.Path]::GetFileNameWithoutExtension($file)     Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name \"$fontName (TrueType)\" -ErrorAction SilentlyContinue     Remove-Item \"$env:windir\\Fonts\\$file\" -Force -ErrorAction SilentlyContinue }"
    ]
  }
