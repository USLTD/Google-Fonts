{
  "autoupdate": {
    "url": [
      "https://raw.githubusercontent.com/google/fonts/main/ofl/cormorantunicase/CormorantUnicase-Light.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/cormorantunicase/CormorantUnicase-Regular.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/cormorantunicase/CormorantUnicase-Medium.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/cormorantunicase/CormorantUnicase-SemiBold.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/cormorantunicase/CormorantUnicase-Bold.ttf"
    ]
  },
  "version": "latest",
  "description": "Cormorant Unicase font family designed by Christian Thalmann",
  "license": "OFL",
  "installer": {
    "script": [
      "$fontFiles = Get-ChildItem \"$dir\" -Filter \"*.ttf\"",
      "foreach ($file in $fontFiles) {",
      "    New-ItemProperty -Path \"HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts\" -Name $file.Name.Replace($file.Extension, \" (TrueType)\") -Value $file.Name -Force | Out-Null",
      "    Copy-Item $file.FullName -Destination \"$env:windir\\Fonts\" -Force",
      "}"
    ]
  },
