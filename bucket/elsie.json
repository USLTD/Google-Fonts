{
  "autoupdate": {
    "url": [
      "https://raw.githubusercontent.com/google/fonts/main/ofl/elsie/Elsie-Regular.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/elsie/Elsie-Black.ttf"
    ]
  },
  "version": "latest",
  "description": "Elsie font family designed by Alejandro Inler",
  "license": "OFL",
  "installer": {
    "script": [
      "$fontFiles = Get-ChildItem \"$dir\" -Filter \"*.ttf\"",
      "foreach ($file in $fontFiles) {",
      "    New-ItemProperty -Path \"HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts\" -Name $file.Name.Replace($file.Extension, \" (TrueType)\") -Value $file.Name -Force | Out-Null",
      "    Copy-Item $file.FullName -Destination \"$env:windir\\Fonts\" -Force",
      "}"
    ]
  },
  "hash": [
    "9B3FF5056866667FB29F60BEB4522994AFDD4D5F580626C6FD9E6F5BF49F1EA5",
    "69339FCD10A5D5C12B72CF5127B44BE5A0147D2531BAF494004C7ADAD4AF6338"
  ],
  "homepage": "https://fonts.google.com/specimen/Elsie",
  "url": [
    "https://raw.githubusercontent.com/google/fonts/main/ofl/elsie/Elsie-Regular.ttf",
    "https://raw.githubusercontent.com/google/fonts/main/ofl/elsie/Elsie-Black.ttf"
  ],
  "checkver": {
    "url": "https://api.github.com/repos/google/fonts/commits?path=ofl/elsie&per_page=1",
    "regex": "\"sha\":\\s*\"([a-f0-9]{7})"
  },
  "uninstaller": {
    "script": [
      "$fontFiles = @(\"Elsie-Regular.ttf\", \"Elsie-Black.ttf\") foreach ($file in $fontFiles) {     $fontName = [System.IO.Path]::GetFileNameWithoutExtension($file)     Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name \"$fontName (TrueType)\" -ErrorAction SilentlyContinue     Remove-Item \"$env:windir\\Fonts\\$file\" -Force -ErrorAction SilentlyContinue }"
    ]
  }
}
