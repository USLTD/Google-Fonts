  ],
  "checkver": {
    "url": "https://api.github.com/repos/google/fonts/commits?path=ofl/chathura&per_page=1",
    "regex": "\"sha\":\\s*\"([a-f0-9]{7})"
  },
  "uninstaller": {
    "script": [
      "$fontFiles = @(\"Chathura-Thin.ttf\", \"Chathura-Light.ttf\", \"Chathura-Regular.ttf\", \"Chathura-Bold.ttf\", \"Chathura-ExtraBold.ttf\") foreach ($file in $fontFiles) {     $fontName = [System.IO.Path]::GetFileNameWithoutExtension($file)     Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name \"$fontName (TrueType)\" -ErrorAction SilentlyContinue     Remove-Item \"$env:windir\\Fonts\\$file\" -Force -ErrorAction SilentlyContinue }"
    ]
  }
