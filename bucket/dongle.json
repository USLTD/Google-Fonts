{
  "autoupdate": {
    "url": [
      "https://raw.githubusercontent.com/google/fonts/main/ofl/dongle/Dongle-Light.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/dongle/Dongle-Regular.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/dongle/Dongle-Bold.ttf"
    ]
  },
  "version": "latest",
  "description": "Dongle font family designed by Yanghee Ryu",
  "license": "OFL",
  "installer": {
    "script": [
      "$fontFiles = Get-ChildItem \"$dir\" -Filter \"*.ttf\"",
      "foreach ($file in $fontFiles) {",
      "    New-ItemProperty -Path \"HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts\" -Name $file.Name.Replace($file.Extension, \" (TrueType)\") -Value $file.Name -Force | Out-Null",
      "    Copy-Item $file.FullName -Destination \"$env:windir\\Fonts\" -Force",
      "}"
    ]
  },
  "hash": [
    "BB04E03DBE44FB0C619434F31565E62B5BAC67229D5ED72EEAC69C2E74E9A45C",
    "2966E7A9D312A868E2B5477BF9A3E59B8CE16BEB76E7E52305AB5897D1CE9741",
    "944C498C0D1A1832AB36F173B1B3AA5AE77B2A914E00C4D79E05338FAE36472D"
  ],
  "homepage": "https://fonts.google.com/specimen/Dongle",
  "url": [
    "https://raw.githubusercontent.com/google/fonts/main/ofl/dongle/Dongle-Light.ttf",
    "https://raw.githubusercontent.com/google/fonts/main/ofl/dongle/Dongle-Regular.ttf",
    "https://raw.githubusercontent.com/google/fonts/main/ofl/dongle/Dongle-Bold.ttf"
  ],
  "checkver": {
    "url": "https://api.github.com/repos/google/fonts/commits?path=ofl/dongle&per_page=1",
    "regex": "\"sha\":\\s*\"([a-f0-9]{7})"
  },
  "uninstaller": {
    "script": [
      "$fontFiles = @(\"Dongle-Light.ttf\", \"Dongle-Regular.ttf\", \"Dongle-Bold.ttf\") foreach ($file in $fontFiles) {     $fontName = [System.IO.Path]::GetFileNameWithoutExtension($file)     Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name \"$fontName (TrueType)\" -ErrorAction SilentlyContinue     Remove-Item \"$env:windir\\Fonts\\$file\" -Force -ErrorAction SilentlyContinue }"
    ]
  }
}
