{
  "autoupdate": {
    "url": [
      "https://raw.githubusercontent.com/google/fonts/main/ofl/baskervville/Baskervville[wght].ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/baskervville/Baskervville-Italic[wght].ttf"
    ]
  },
  "version": "latest",
  "description": "Baskervville font family designed by ANRT",
  "license": "OFL",
  "installer": {
    "script": [
      "$fontFiles = Get-ChildItem \"$dir\" -Filter \"*.ttf\"",
      "foreach ($file in $fontFiles) {",
      "    New-ItemProperty -Path \"HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts\" -Name $file.Name.Replace($file.Extension, \" (TrueType)\") -Value $file.Name -Force | Out-Null",
      "    Copy-Item $file.FullName -Destination \"$env:windir\\Fonts\" -Force",
      "}"
    ]
  },
  "hash": [
    "A08BCF988383B344AACFD34365A8CD408A4A9665CAAF19DC0D716A93833A0FA7",
    "279FF53ED5C733EFABB206345AF87FACE1C137B8AB2667298D6CF228EBFFBF01"
  ],
  "homepage": "https://fonts.google.com/specimen/Baskervville",
  "url": [
    "https://raw.githubusercontent.com/google/fonts/main/ofl/baskervville/Baskervville[wght].ttf",
    "https://raw.githubusercontent.com/google/fonts/main/ofl/baskervville/Baskervville-Italic[wght].ttf"
  ],
  "checkver": {
    "url": "https://api.github.com/repos/google/fonts/commits?path=ofl/baskervville&per_page=1",
    "regex": "\"sha\":\\s*\"([a-f0-9]{7})"
  },
  "uninstaller": {
    "script": [
      "$fontFiles = @(\"Baskervville[wght].ttf\", \"Baskervville-Italic[wght].ttf\") foreach ($file in $fontFiles) {     $fontName = [System.IO.Path]::GetFileNameWithoutExtension($file)     Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name \"$fontName (TrueType)\" -ErrorAction SilentlyContinue     Remove-Item \"$env:windir\\Fonts\\$file\" -Force -ErrorAction SilentlyContinue }"
    ]
  }
}
