{
  "autoupdate": {
    "url": [
      "https://raw.githubusercontent.com/google/fonts/main/ofl/alumnisanscollegiateone/AlumniSansCollegiateOne-Regular.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/alumnisanscollegiateone/AlumniSansCollegiateOne-Italic.ttf"
    ]
  },
  "version": "latest",
  "description": "Alumni Sans Collegiate One font family designed by Robert Leuschke",
  "license": "OFL",
  "installer": {
    "script": [
      "$fontFiles = Get-ChildItem \"$dir\" -Filter \"*.ttf\"",
      "foreach ($file in $fontFiles) {",
      "    New-ItemProperty -Path \"HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts\" -Name $file.Name.Replace($file.Extension, \" (TrueType)\") -Value $file.Name -Force | Out-Null",
      "    Copy-Item $file.FullName -Destination \"$env:windir\\Fonts\" -Force",
      "}"
    ]
  },
  "hash": [
    "9BD48B280391794C7A5AEA97476B25051B4705C7963E4B63B2C84876DB31B59B",
    "AA1EC3CAFA94926B00E61DA029C48271E6845400167C10F8B659B938DA9D54EE"
  ],
  "homepage": "https://fonts.google.com/specimen/Alumni+Sans+Collegiate+One",
  "url": [
    "https://raw.githubusercontent.com/google/fonts/main/ofl/alumnisanscollegiateone/AlumniSansCollegiateOne-Regular.ttf",
    "https://raw.githubusercontent.com/google/fonts/main/ofl/alumnisanscollegiateone/AlumniSansCollegiateOne-Italic.ttf"
  ],
  "checkver": {
    "url": "https://api.github.com/repos/google/fonts/commits?path=ofl/alumnisanscollegiateone&per_page=1",
    "regex": "\"sha\":\\s*\"([a-f0-9]{7})"
  },
  "uninstaller": {
    "script": [
      "$fontFiles = @(\"AlumniSansCollegiateOne-Regular.ttf\", \"AlumniSansCollegiateOne-Italic.ttf\") foreach ($file in $fontFiles) {     $fontName = [System.IO.Path]::GetFileNameWithoutExtension($file)     Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name \"$fontName (TrueType)\" -ErrorAction SilentlyContinue     Remove-Item \"$env:windir\\Fonts\\$file\" -Force -ErrorAction SilentlyContinue }"
    ]
  }
}
