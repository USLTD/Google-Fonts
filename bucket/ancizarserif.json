{
  "autoupdate": {
    "url": [
      "https://raw.githubusercontent.com/google/fonts/main/ofl/ancizarserif/AncizarSerif[wght].ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/ancizarserif/AncizarSerif-Italic[wght].ttf"
    ]
  },
  "version": "latest",
  "description": "Ancizar Serif font family designed by Universidad Nacional de Colombia (UNAL), César Puertas, Viviana Monsalve, Julián Moncada",
  "license": "OFL",
  "installer": {
    "script": [
      "$fontFiles = Get-ChildItem \"$dir\" -Filter \"*.ttf\"",
      "foreach ($file in $fontFiles) {",
      "    New-ItemProperty -Path \"HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts\" -Name $file.Name.Replace($file.Extension, \" (TrueType)\") -Value $file.Name -Force | Out-Null",
      "    Copy-Item $file.FullName -Destination \"$env:windir\\Fonts\" -Force",
      "}"
    ]
  },
  "hash": [
    "FCC35D7FE2780846344D7187515D483BB69F3D9BCC49C4833A219E4D9109DB98",
    "B30F075790E14795508A42DDA7B8F6269509E15A13A4C653B3665662BDFBF45C"
  ],
  "homepage": "https://fonts.google.com/specimen/Ancizar+Serif",
  "url": [
    "https://raw.githubusercontent.com/google/fonts/main/ofl/ancizarserif/AncizarSerif[wght].ttf",
    "https://raw.githubusercontent.com/google/fonts/main/ofl/ancizarserif/AncizarSerif-Italic[wght].ttf"
  ],
  "checkver": {
    "url": "https://api.github.com/repos/google/fonts/commits?path=ofl/ancizarserif&per_page=1",
    "regex": "\"sha\":\\s*\"([a-f0-9]{7})"
  },
  "uninstaller": {
    "script": [
      "$fontFiles = @(\"AncizarSerif[wght].ttf\", \"AncizarSerif-Italic[wght].ttf\") foreach ($file in $fontFiles) {     $fontName = [System.IO.Path]::GetFileNameWithoutExtension($file)     Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name \"$fontName (TrueType)\" -ErrorAction SilentlyContinue     Remove-Item \"$env:windir\\Fonts\\$file\" -Force -ErrorAction SilentlyContinue }"
    ]
  }
}
