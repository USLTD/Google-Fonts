  "uninstaller": {
    "script": [
      "$fontFiles = @(\"Akatab-Regular.ttf\", \"Akatab-Medium.ttf\", \"Akatab-SemiBold.ttf\", \"Akatab-Bold.ttf\", \"Akatab-ExtraBold.ttf\", \"Akatab-Black.ttf\") foreach ($file in $fontFiles) {     $fontName = [System.IO.Path]::GetFileNameWithoutExtension($file)     Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name \"$fontName (TrueType)\" -ErrorAction SilentlyContinue     Remove-Item \"$env:windir\\Fonts\\$file\" -Force -ErrorAction SilentlyContinue }"
    ]
