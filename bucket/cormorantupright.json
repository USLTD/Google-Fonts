{
  "autoupdate": {
    "url": [
      "https://raw.githubusercontent.com/google/fonts/main/ofl/cormorantupright/CormorantUpright-Light.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/cormorantupright/CormorantUpright-Regular.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/cormorantupright/CormorantUpright-Medium.ttf",
