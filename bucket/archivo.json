{
  "autoupdate": {
    "url": [
      "https://raw.githubusercontent.com/google/fonts/main/ofl/archivo/Archivo[wdth,wght].ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/archivo/Archivo-Italic[wdth,wght].ttf"
    ]
  },
  "version": "latest",
  "description": "Archivo font family designed by Omnibus-Type",
  "license": "OFL",
  "installer": {
    "script": [
      "$fontFiles = Get-ChildItem \"$dir\" -Filter \"*.ttf\"",
      "foreach ($file in $fontFiles) {",
      "    New-ItemProperty -Path \"HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts\" -Name $file.Name.Replace($file.Extension, \" (TrueType)\") -Value $file.Name -Force | Out-Null",
      "    Copy-Item $file.FullName -Destination \"$env:windir\\Fonts\" -Force",
      "}"
    ]
  },
  "hash": [
    "0E094A7D3C7C4C25CF1310C4B30014F1DAE9332220B1C2C88F4FA996F0B05053",
    "305D13B4EB80E62F7D517F78D7C045250D977552A420F2DBED906F314E761305"
  ],
  "homepage": "https://fonts.google.com/specimen/Archivo",
  "url": [
    "https://raw.githubusercontent.com/google/fonts/main/ofl/archivo/Archivo[wdth,wght].ttf",
    "https://raw.githubusercontent.com/google/fonts/main/ofl/archivo/Archivo-Italic[wdth,wght].ttf"
  ],
  "checkver": {
    "url": "https://api.github.com/repos/google/fonts/commits?path=ofl/archivo&per_page=1",
    "regex": "\"sha\":\\s*\"([a-f0-9]{7})"
  },
  "uninstaller": {
    "script": [
      "$fontFiles = @(\"Archivo[wdth,wght].ttf\", \"Archivo-Italic[wdth,wght].ttf\") foreach ($file in $fontFiles) {     $fontName = [System.IO.Path]::GetFileNameWithoutExtension($file)     Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name \"$fontName (TrueType)\" -ErrorAction SilentlyContinue     Remove-Item \"$env:windir\\Fonts\\$file\" -Force -ErrorAction SilentlyContinue }"
    ]
  }
}
