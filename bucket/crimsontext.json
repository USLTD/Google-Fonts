  "uninstaller": {
    "script": [
      "$fontFiles = @(\"CrimsonText-Regular.ttf\", \"CrimsonText-Italic.ttf\", \"CrimsonText-SemiBold.ttf\", \"CrimsonText-SemiBoldItalic.ttf\", \"CrimsonText-Bold.ttf\", \"CrimsonText-BoldItalic.ttf\") foreach ($file in $fontFiles) {     $fontName = [System.IO.Path]::GetFileNameWithoutExtension($file)     Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name \"$fontName (TrueType)\" -ErrorAction SilentlyContinue     Remove-Item \"$env:windir\\Fonts\\$file\" -Force -ErrorAction SilentlyContinue }"
