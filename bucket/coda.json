{
  "autoupdate": {
    "url": [
      "https://raw.githubusercontent.com/google/fonts/main/ofl/coda/Coda-Regular.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/coda/Coda-ExtraBold.ttf"
    ]
  },
  "version": "latest",
  "description": "Coda font family designed by Vernon Adams",
  "license": "OFL",
  "installer": {
    "script": [
      "$fontFiles = Get-ChildItem \"$dir\" -Filter \"*.ttf\"",
      "foreach ($file in $fontFiles) {",
      "    New-ItemProperty -Path \"HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts\" -Name $file.Name.Replace($file.Extension, \" (TrueType)\") -Value $file.Name -Force | Out-Null",
      "    Copy-Item $file.FullName -Destination \"$env:windir\\Fonts\" -Force",
      "}"
    ]
  },
  "hash": [
    "F5D32AE9D5C78CDAB7E75A52BD1DA07AE22644597232D085A5CE7CD1AF341E17",
    "35909E4C6907E1391D09BAA934C5E7A4ABB232DEDEA58E47ACAA4AECD165C65C"
  ],
  "homepage": "https://fonts.google.com/specimen/Coda",
  "url": [
    "https://raw.githubusercontent.com/google/fonts/main/ofl/coda/Coda-Regular.ttf",
    "https://raw.githubusercontent.com/google/fonts/main/ofl/coda/Coda-ExtraBold.ttf"
  ],
  "checkver": {
    "url": "https://api.github.com/repos/google/fonts/commits?path=ofl/coda&per_page=1",
    "regex": "\"sha\":\\s*\"([a-f0-9]{7})"
  },
  "uninstaller": {
    "script": [
      "$fontFiles = @(\"Coda-Regular.ttf\", \"Coda-ExtraBold.ttf\") foreach ($file in $fontFiles) {     $fontName = [System.IO.Path]::GetFileNameWithoutExtension($file)     Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name \"$fontName (TrueType)\" -ErrorAction SilentlyContinue     Remove-Item \"$env:windir\\Fonts\\$file\" -Force -ErrorAction SilentlyContinue }"
    ]
  }
}
