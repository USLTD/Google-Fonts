{
  "autoupdate": {
    "url": [
      "https://raw.githubusercontent.com/google/fonts/main/ofl/anonymouspro/AnonymousPro-Regular.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/anonymouspro/AnonymousPro-Italic.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/anonymouspro/AnonymousPro-Bold.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/anonymouspro/AnonymousPro-BoldItalic.ttf"
    ]
  },
  "version": "latest",
  "description": "Anonymous Pro font family designed by Mark Simonson",
  "license": "OFL",
  "installer": {
    "script": [
      "$fontFiles = Get-ChildItem \"$dir\" -Filter \"*.ttf\"",
      "foreach ($file in $fontFiles) {",
      "    New-ItemProperty -Path \"HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts\" -Name $file.Name.Replace($file.Extension, \" (TrueType)\") -Value $file.Name -Force | Out-Null",
      "    Copy-Item $file.FullName -Destination \"$env:windir\\Fonts\" -Force",
      "}"
    ]
  },
  "hash": [
    "46D8B9A5F4B38FC9D30F3CDD676D4C6F78A9BEF949BB1A8304216CC731EB87F8",
    "BC13AC34E9994128C61B54BF4E78A8ADB439B543EA0B19761D159342599F441A",
    "52895657E7D48860089EBFAC63A27244F37A2218EC9C5019A0B37FE885C0FC0C",
    "4E811E1E3B60FC763FB24ACD27781E72241A8380BEB0FFA5E07AF2B87133496D"
  ],
  "homepage": "https://fonts.google.com/specimen/Anonymous+Pro",
  "url": [
    "https://raw.githubusercontent.com/google/fonts/main/ofl/anonymouspro/AnonymousPro-Regular.ttf",
    "https://raw.githubusercontent.com/google/fonts/main/ofl/anonymouspro/AnonymousPro-Italic.ttf",
    "https://raw.githubusercontent.com/google/fonts/main/ofl/anonymouspro/AnonymousPro-Bold.ttf",
    "https://raw.githubusercontent.com/google/fonts/main/ofl/anonymouspro/AnonymousPro-BoldItalic.ttf"
  ],
  "checkver": {
    "url": "https://api.github.com/repos/google/fonts/commits?path=ofl/anonymouspro&per_page=1",
    "regex": "\"sha\":\\s*\"([a-f0-9]{7})"
  },
  "uninstaller": {
    "script": [
      "$fontFiles = @(\"AnonymousPro-Regular.ttf\", \"AnonymousPro-Italic.ttf\", \"AnonymousPro-Bold.ttf\", \"AnonymousPro-BoldItalic.ttf\") foreach ($file in $fontFiles) {     $fontName = [System.IO.Path]::GetFileNameWithoutExtension($file)     Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name \"$fontName (TrueType)\" -ErrorAction SilentlyContinue     Remove-Item \"$env:windir\\Fonts\\$file\" -Force -ErrorAction SilentlyContinue }"
    ]
  }
}
