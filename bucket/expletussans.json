{
  "autoupdate": {
    "url": [
      "https://raw.githubusercontent.com/google/fonts/main/ofl/expletussans/ExpletusSans[wght].ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/expletussans/ExpletusSans-Italic[wght].ttf"
    ]
  },
  "version": "latest",
  "description": "Expletus Sans font family designed by Designtown",
  "license": "OFL",
  "installer": {
    "script": [
      "$fontFiles = Get-ChildItem \"$dir\" -Filter \"*.ttf\"",
      "foreach ($file in $fontFiles) {",
      "    New-ItemProperty -Path \"HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts\" -Name $file.Name.Replace($file.Extension, \" (TrueType)\") -Value $file.Name -Force | Out-Null",
      "    Copy-Item $file.FullName -Destination \"$env:windir\\Fonts\" -Force",
      "}"
    ]
  },
  "hash": [
    "33508B3B477C548AC00179D97C6DEACA1E98DAB4CC1D869DEC5815931E7540F8",
    "5E69F9842EF3BDDF9DB581642306216F9D25649B9F9DE2E80944E694AC189799"
  ],
  "homepage": "https://fonts.google.com/specimen/Expletus+Sans",
  "url": [
    "https://raw.githubusercontent.com/google/fonts/main/ofl/expletussans/ExpletusSans[wght].ttf",
    "https://raw.githubusercontent.com/google/fonts/main/ofl/expletussans/ExpletusSans-Italic[wght].ttf"
  ],
  "checkver": {
    "url": "https://api.github.com/repos/google/fonts/commits?path=ofl/expletussans&per_page=1",
    "regex": "\"sha\":\\s*\"([a-f0-9]{7})"
  },
  "uninstaller": {
    "script": [
      "$fontFiles = @(\"ExpletusSans[wght].ttf\", \"ExpletusSans-Italic[wght].ttf\") foreach ($file in $fontFiles) {     $fontName = [System.IO.Path]::GetFileNameWithoutExtension($file)     Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name \"$fontName (TrueType)\" -ErrorAction SilentlyContinue     Remove-Item \"$env:windir\\Fonts\\$file\" -Force -ErrorAction SilentlyContinue }"
    ]
  }
}
