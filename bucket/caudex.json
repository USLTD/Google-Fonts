    "880FB67901CE94573ED0262D152B87115A08F928C72FC6C1101375A1223D390A",
    "78440E8AB6730581AC71FE780AD2FA15BA15D240313028678E404ACE4E70EB20"
  ],
  "homepage": "https://fonts.google.com/specimen/Caudex",
  "url": [
    "https://raw.githubusercontent.com/google/fonts/main/ofl/caudex/Caudex-Regular.ttf",
    "https://raw.githubusercontent.com/google/fonts/main/ofl/caudex/Caudex-Italic.ttf",
    "https://raw.githubusercontent.com/google/fonts/main/ofl/caudex/Caudex-Bold.ttf",
    "https://raw.githubusercontent.com/google/fonts/main/ofl/caudex/Caudex-BoldItalic.ttf"
  ],
  "checkver": {
    "url": "https://api.github.com/repos/google/fonts/commits?path=ofl/caudex&per_page=1",
    "regex": "\"sha\":\\s*\"([a-f0-9]{7})"
  },
  "uninstaller": {
    "script": [
      "$fontFiles = @(\"Caudex-Regular.ttf\", \"Caudex-Italic.ttf\", \"Caudex-Bold.ttf\", \"Caudex-BoldItalic.ttf\") foreach ($file in $fontFiles) {     $fontName = [System.IO.Path]::GetFileNameWithoutExtension($file)     Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name \"$fontName (TrueType)\" -ErrorAction SilentlyContinue     Remove-Item \"$env:windir\\Fonts\\$file\" -Force -ErrorAction SilentlyContinue }"
    ]
  }
}
