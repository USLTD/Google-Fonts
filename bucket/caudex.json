{
  "autoupdate": {
    "url": [
      "https://raw.githubusercontent.com/google/fonts/main/ofl/caudex/Caudex-Regular.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/caudex/Caudex-Italic.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/caudex/Caudex-Bold.ttf",
      "https://raw.githubusercontent.com/google/fonts/main/ofl/caudex/Caudex-BoldItalic.ttf"
    ]
  },
  "version": "latest",
  "description": "Caudex font family designed by Nidud",
  "license": "OFL",
  "installer": {
    "script": [
      "$fontFiles = Get-ChildItem \"$dir\" -Filter \"*.ttf\"",
      "foreach ($file in $fontFiles) {",
      "    New-ItemProperty -Path \"HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts\" -Name $file.Name.Replace($file.Extension, \" (TrueType)\") -Value $file.Name -Force | Out-Null",
      "    Copy-Item $file.FullName -Destination \"$env:windir\\Fonts\" -Force",
      "}"
    ]
  },
  "hash": [
    "DBB493E1ADC50AAEC52071535E6FCCF4176793C79545F54D95A812CBFB85169B",
